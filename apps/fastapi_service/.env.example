# ═══════════════════════════════════════════════════════════════════════
# ARIES FastAPI Service — Environment Variables
# Copy to .env and fill in production values
#
# Default credentials match the MLOps stack (MLOps/.env).
# Infrastructure (PostgreSQL, MinIO, MLflow) is shared via aries_network.
# ═══════════════════════════════════════════════════════════════════════

# ── Service ───────────────────────────────────────────────────────────
ARIES_SERVICE_NAME=aries-fastapi-service
ARIES_SERVICE_VERSION=1.0.0                                                                                                                                                
ARIES_LOG_LEVEL=INFO
ARIES_DEBUG=false

# ── PostgreSQL (shared with MLOps stack) ──────────────────────────────
# Uses the same postgres instance as MLflow, but a separate 'aries' database.
# The MLOps init.sql creates both 'mlflow_db' and 'aries' databases.
ARIES_DATABASE_URL=postgresql://admin:password123@postgres:5432/aries

# ── Kafka ─────────────────────────────────────────────────────────────
ARIES_KAFKA_BOOTSTRAP_SERVERS=kafka:9092

# ── Redis ─────────────────────────────────────────────────────────────
ARIES_REDIS_URL=redis://redis:6379/0

# ── MinIO / S3 (shared with MLOps stack) ──────────────────────────────
# Uses the same MinIO instance as MLflow. Models are fetched from mlflow-bucket.
ARIES_S3_ENDPOINT_URL=http://minio:9000
ARIES_S3_BUCKET_MODELS=mlflow-bucket
ARIES_S3_ACCESS_KEY=admin
ARIES_S3_SECRET_KEY=password123

# ── MLflow (shared with MLOps stack) ──────────────────────────────────
# On startup, FastAPI queries MLflow to discover the latest trained model.
ARIES_MLFLOW_TRACKING_URI=http://mlflow:5000

# ── Fallback Model S3 Keys (used only if MLflow is unreachable) ──────
ARIES_MODEL_TRIAGE_S3_KEY=triage/triage.onnx
ARIES_MODEL_NER_S3_KEY=ner/ner.opt.onnx
ARIES_MODEL_NER_TOKENIZER_S3_PREFIX=ner/tokenizer/
ARIES_MODEL_SUMMARIZER_ENCODER_S3_KEY=summarizer/encoder.onnx
ARIES_MODEL_SUMMARIZER_DECODER_S3_KEY=summarizer/decoder.onnx
ARIES_MODEL_SUMMARIZER_TOKENIZER_S3_PREFIX=summarizer/tokenizer/

# ── Inference ─────────────────────────────────────────────────────────
ARIES_SUMMARIZER_BACKEND=onnx
ARIES_USE_SLM=true
ARIES_SLM_MODEL_PATH=/tmp/aries_models/slm/Phi-3-mini-4k-instruct-q4.gguf
ARIES_AUTO_CLOSE_THRESHOLD=0.01
ARIES_TRIAGE_WEIGHT_ML=0.50
ARIES_TRIAGE_WEIGHT_ASSET=0.30
ARIES_TRIAGE_WEIGHT_BEHAVIOR=0.20
